# Marketplace Milestone 22: Razorpay payment gateway.
# Keep real merchant credentials only in deployment secrets / Razorpay dashboard.
PAYMENT_PROVIDER="razorpay"
# Razorpay Key ID (safe to expose to Checkout, but still configure through deployment env).
PAYMENT_PROVIDER_PUBLIC_KEY=""
# Razorpay Key Secret (server-only).
PAYMENT_PROVIDER_SECRET_KEY=""
# Razorpay webhook secret used to verify x-razorpay-signature over the raw request body.
PAYMENT_WEBHOOK_SECRET=""
# Configure the Razorpay webhook URL as:
# https://YOUR_DOMAIN/api/payments/razorpay/webhook

# Marketplace Milestone 26: external identity/business verification provider.
# Leave empty until a provider is selected and its data-processing terms are approved.
VERIFICATION_PROVIDER=""
VERIFICATION_PROVIDER_API_KEY=""
VERIFICATION_WEBHOOK_SECRET=""
