DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/yartong?schema=public"
AUTH_SECRET="replace-with-a-generated-secret"
AUTH_URL="http://localhost:3000"
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""
# Facebook OAuth app credentials. Configure callback as:
# https://YOUR_DOMAIN/api/auth/callback/facebook
AUTH_FACEBOOK_ID=""
AUTH_FACEBOOK_SECRET=""
# QA-only seeded email login. Never use a real user password here.
ENABLE_DEMO_LOGIN="false"
DEMO_LOGIN_PASSWORD=""
# Future phone/OTP integration placeholders
OTP_PROVIDER_API_KEY=""
OTP_SENDER_ID=""
# Marketplace Milestone 22: Razorpay payment gateway.
# Keep real merchant credentials only in deployment secrets / Razorpay dashboard.
PAYMENT_PROVIDER="razorpay"
# Razorpay Key ID (safe to expose to Checkout, but still configure through deployment env).
PAYMENT_PROVIDER_PUBLIC_KEY=""
# Razorpay Key Secret (server-only).
PAYMENT_PROVIDER_SECRET_KEY=""
# Razorpay webhook secret used to verify x-razorpay-signature over the raw request body.
PAYMENT_WEBHOOK_SECRET=""
# Configure the Razorpay webhook URL as:
# https://YOUR_DOMAIN/api/payments/razorpay/webhook

# Marketplace Milestone 26: external identity/business verification provider.
# Leave empty until a provider is selected and its data-processing terms are approved.
VERIFICATION_PROVIDER=""
VERIFICATION_PROVIDER_API_KEY=""
VERIFICATION_WEBHOOK_SECRET=""

# Marketplace Milestone 24: optional external notification delivery.
# The in-app notification record remains authoritative even when delivery is enabled.
# Leave empty until an email/SMS/push provider and approved credentials are configured.
NOTIFICATION_PROVIDER=""
NOTIFICATION_PROVIDER_API_KEY=""
# Comma-separated subset of: email,sms,push
NOTIFICATION_CHANNELS=""
# Provider-specific sender identities remain deployment-only.
NOTIFICATION_EMAIL_FROM=""
NOTIFICATION_SMS_SENDER=""
NOTIFICATION_PUSH_APP_ID=""