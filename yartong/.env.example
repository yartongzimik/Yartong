# PostgreSQL connection string. Never commit real credentials.
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?schema=public"

# Auth.js secret. Generate locally with: npx auth secret
AUTH_SECRET="replace-with-a-long-random-secret"
AUTH_URL="http://localhost:3000"

# Optional Google OAuth provider placeholders for future production login.
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# Future phone/OTP integration placeholders.
PHONE_OTP_PROVIDER=""
PHONE_OTP_API_KEY=""
