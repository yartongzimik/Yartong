generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  CUSTOMER
  SKILLED_PROVIDER
  LABOURER
  CONTRACTOR
  MATERIAL_SUPPLIER
  ADMIN
  ONBOARDING_PENDING
}

enum AccountStatus {
  PENDING
  ACTIVE
  SUSPENDED
  REJECTED
  DEACTIVATED
}

enum VerificationStatus {
  UNVERIFIED
  PHONE_VERIFIED
  IDENTITY_VERIFIED
  BUSINESS_VERIFIED
  YARTONG_VERIFIED
}

enum JobStatus {
  DRAFT
  PUBLISHED
  CLOSED
  CANCELLED
}

enum JobUrgency {
  STANDARD
  WITHIN_24_HOURS
  EMERGENCY
}

enum JobBudgetType {
  FIXED
  RANGE
  NEGOTIABLE
}

enum JobProviderRole {
  SKILLED_PROVIDER
  LABOURER
  CONTRACTOR
}

enum ApplicationStatus {
  SUBMITTED
  SHORTLISTED
  ACCEPTED
  REJECTED
  WITHDRAWN
}

enum EngagementStatus {
  PENDING
  CONFIRMED
  IN_PROGRESS
  COMPLETED
  CANCELLED
  DISPUTED
}

enum ReviewStatus {
  PUBLISHED
  FLAGGED
  HIDDEN
}

enum VerificationRequestType {
  IDENTITY
  BUSINESS
  PROFESSIONAL_CREDENTIAL
}

enum VerificationRequestStatus {
  SUBMITTED
  UNDER_REVIEW
  APPROVED
  REJECTED
  CANCELLED
}

enum QuoteStatus {
  SUBMITTED
  ACCEPTED
  REJECTED
  WITHDRAWN
  SUPERSEDED
}

model User {
  id                 String             @id @default(cuid())
  displayName        String             @default("")
  name               String?
  email              String?            @unique
  emailVerified      DateTime?
  phoneNumber        String?            @unique
  image              String?
  primaryRole        UserRole           @default(ONBOARDING_PENDING)
  accountStatus      AccountStatus      @default(ACTIVE)
  verificationStatus VerificationStatus @default(UNVERIFIED)
  primaryLocationId  String?
  primaryLocation    Location?          @relation(fields: [primaryLocationId], references: [id], onDelete: SetNull)
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
  lastActiveAt       DateTime?
  isDemo             Boolean            @default(false)

  accounts                Account[]
  sessions                Session[]
  customerProfile         CustomerProfile?
  skilledProviderProfile  SkilledProviderProfile?
  labourerProfile         LabourerProfile?
  contractorProfile       ContractorProfile?
  materialSupplierProfile MaterialSupplierProfile?
  jobs                    Job[]
  jobApplications         JobApplication[]         @relation("ApplicationProvider")
  customerEngagements     Engagement[]             @relation("EngagementCustomer")
  providerEngagements     Engagement[]             @relation("EngagementProvider")
  customerConversations   Conversation[]           @relation("ConversationCustomer")
  providerConversations   Conversation[]           @relation("ConversationProvider")
  sentMessages            Message[]                @relation("MessageSender")
  authoredReviews         Review[]                 @relation("ReviewAuthor")
  receivedReviews         Review[]                 @relation("ReviewSubject")
  verificationRequests    VerificationRequest[]    @relation("VerificationApplicant")
  reviewedVerifications   VerificationRequest[]    @relation("VerificationReviewer")
  createdQuotes           EngagementQuote[]        @relation("QuoteCreator")

  @@index([primaryRole])
  @@index([accountStatus])
  @@index([primaryLocationId])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Location {
  id        String   @id @default(cuid())
  slug      String   @unique
  name      String
  district  String
  state     String
  country   String   @default("India")
  pincode   String?
  latitude  Decimal? @db.Decimal(9, 6)
  longitude Decimal? @db.Decimal(9, 6)
  isActive  Boolean  @default(true)
  isPrimary Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  primaryUsers User[]
  jobs         Job[]

  @@index([district, state, country])
  @@index([isActive])
}

model CustomerProfile {
  id                 String   @id @default(cuid())
  userId             String   @unique
  onboardingComplete Boolean  @default(false)
  bio                String?  @db.VarChar(500)
  preferredLanguages String[] @default([])
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model SkilledProviderProfile {
  id                 String   @id @default(cuid())
  userId             String   @unique
  onboardingComplete Boolean  @default(false)
  businessName       String?
  headline           String?
  bio                String?  @db.VarChar(800)
  experienceYears    Int?
  skills             String[] @default([])
  serviceRadiusKm    Int?
  availableForWork   Boolean  @default(true)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model LabourerProfile {
  id                 String   @id @default(cuid())
  userId             String   @unique
  onboardingComplete Boolean  @default(false)
  headline           String?
  bio                String?  @db.VarChar(500)
  experienceYears    Int?
  skills             String[] @default([])
  availableForWork   Boolean  @default(true)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ContractorProfile {
  id                 String   @id @default(cuid())
  userId             String   @unique
  onboardingComplete Boolean  @default(false)
  businessName       String?
  headline           String?
  bio                String?  @db.VarChar(800)
  experienceYears    Int?
  teamSize           Int?
  projectTypes       String[] @default([])
  serviceRadiusKm    Int?
  availableForWork   Boolean  @default(true)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model MaterialSupplierProfile {
  id                 String   @id @default(cuid())
  userId             String   @unique
  onboardingComplete Boolean  @default(false)
  businessName       String?
  headline           String?
  bio                String?  @db.VarChar(800)
  materialCategories String[] @default([])
  deliveryAvailable  Boolean  @default(false)
  deliveryRadiusKm   Int?
  wholesaleAvailable Boolean  @default(false)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Job {
  id                  String            @id @default(cuid())
  customerId          String
  locationId          String
  title               String            @db.VarChar(120)
  description         String            @db.Text
  category            String            @db.VarChar(120)
  skills              String[]          @default([])
  targetProviderRoles JobProviderRole[] @default([])
  budgetType          JobBudgetType
  budgetMin           Int?
  budgetMax           Int?
  currency            String            @default("INR") @db.VarChar(3)
  urgency             JobUrgency        @default(STANDARD)
  preferredStartDate  DateTime?
  status              JobStatus         @default(DRAFT)
  publishedAt         DateTime?
  closedAt            DateTime?
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt

  customer     User             @relation(fields: [customerId], references: [id], onDelete: Cascade)
  location     Location         @relation(fields: [locationId], references: [id], onDelete: Restrict)
  applications JobApplication[]
  engagement   Engagement?

  @@index([customerId])
  @@index([locationId])
  @@index([status])
  @@index([publishedAt])
  @@index([status, publishedAt])
}

model JobApplication {
  id                   String            @id @default(cuid())
  jobId                String
  providerId           String
  providerRole         JobProviderRole
  message              String            @db.VarChar(2000)
  proposedPrice        Int?
  proposedTimelineDays Int?
  status               ApplicationStatus @default(SUBMITTED)
  createdAt            DateTime          @default(now())
  updatedAt            DateTime          @updatedAt

  job        Job         @relation(fields: [jobId], references: [id], onDelete: Cascade)
  provider   User        @relation("ApplicationProvider", fields: [providerId], references: [id], onDelete: Cascade)
  engagement Engagement?

  @@unique([jobId, providerId])
  @@index([jobId, status])
  @@index([providerId, status])
}

model Engagement {
  id                   String           @id @default(cuid())
  jobId                String           @unique
  applicationId        String           @unique
  customerId           String
  providerId           String
  providerRole         JobProviderRole
  scope                String           @db.Text
  agreedPrice          Int?
  currency             String           @default("INR") @db.VarChar(3)
  proposedTimelineDays Int?
  status               EngagementStatus @default(PENDING)
  confirmedAt          DateTime?
  startedAt            DateTime?
  completedAt          DateTime?
  cancelledAt          DateTime?
  disputedAt           DateTime?
  createdAt            DateTime         @default(now())
  updatedAt            DateTime         @updatedAt

  job          Job               @relation(fields: [jobId], references: [id], onDelete: Restrict)
  application  JobApplication    @relation(fields: [applicationId], references: [id], onDelete: Restrict)
  customer     User              @relation("EngagementCustomer", fields: [customerId], references: [id], onDelete: Restrict)
  provider     User              @relation("EngagementProvider", fields: [providerId], references: [id], onDelete: Restrict)
  conversation Conversation?
  reviews      Review[]
  quotes       EngagementQuote[]

  @@index([customerId, status])
  @@index([providerId, status])
  @@index([status, createdAt])
}

model Conversation {
  id            String   @id @default(cuid())
  engagementId  String   @unique
  customerId    String
  providerId    String
  lastMessageAt DateTime @default(now())
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  engagement Engagement @relation(fields: [engagementId], references: [id], onDelete: Restrict)
  customer   User       @relation("ConversationCustomer", fields: [customerId], references: [id], onDelete: Restrict)
  provider   User       @relation("ConversationProvider", fields: [providerId], references: [id], onDelete: Restrict)
  messages   Message[]

  @@index([customerId, lastMessageAt])
  @@index([providerId, lastMessageAt])
}

model Message {
  id             String    @id @default(cuid())
  conversationId String
  senderId       String
  body           String    @db.VarChar(4000)
  readAt         DateTime?
  createdAt      DateTime  @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender       User         @relation("MessageSender", fields: [senderId], references: [id], onDelete: Restrict)

  @@index([conversationId, createdAt])
  @@index([senderId, createdAt])
}

model Review {
  id           String       @id @default(cuid())
  engagementId String
  authorId     String
  subjectId    String
  rating       Int
  title        String?      @db.VarChar(120)
  comment      String?      @db.VarChar(3000)
  status       ReviewStatus @default(PUBLISHED)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  engagement Engagement @relation(fields: [engagementId], references: [id], onDelete: Restrict)
  author     User       @relation("ReviewAuthor", fields: [authorId], references: [id], onDelete: Restrict)
  subject    User       @relation("ReviewSubject", fields: [subjectId], references: [id], onDelete: Restrict)

  @@unique([engagementId, authorId])
  @@index([subjectId, status, createdAt])
  @@index([authorId, createdAt])
}

model VerificationRequest {
  id            String                    @id @default(cuid())
  userId        String
  type          VerificationRequestType
  status        VerificationRequestStatus @default(SUBMITTED)
  applicantNote String?                   @db.VarChar(2000)
  reviewerId    String?
  reviewerNote  String?                   @db.VarChar(2000)
  providerName  String?                   @db.VarChar(120)
  providerRef   String?                   @db.VarChar(255)
  submittedAt   DateTime                  @default(now())
  reviewedAt    DateTime?
  createdAt     DateTime                  @default(now())
  updatedAt     DateTime                  @updatedAt

  applicant User  @relation("VerificationApplicant", fields: [userId], references: [id], onDelete: Cascade)
  reviewer  User? @relation("VerificationReviewer", fields: [reviewerId], references: [id], onDelete: SetNull)

  @@index([userId, status, createdAt])
  @@index([status, type, submittedAt])
  @@index([reviewerId, reviewedAt])
}

model EngagementQuote {
  id           String      @id @default(cuid())
  engagementId String
  createdById  String
  amount       Int
  currency     String      @default("INR") @db.VarChar(3)
  scope        String      @db.Text
  timelineDays Int?
  note         String?     @db.VarChar(2000)
  status       QuoteStatus @default(SUBMITTED)
  submittedAt  DateTime    @default(now())
  respondedAt  DateTime?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  engagement Engagement @relation(fields: [engagementId], references: [id], onDelete: Restrict)
  createdBy  User       @relation("QuoteCreator", fields: [createdById], references: [id], onDelete: Restrict)

  @@index([engagementId, status, submittedAt])
  @@index([createdById, createdAt])
}
