generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  CUSTOMER
  SKILLED_PROVIDER
  LABOURER
  CONTRACTOR
  MATERIAL_SUPPLIER
  ADMIN
}

enum AccountStatus {
  PENDING
  ACTIVE
  SUSPENDED
  REJECTED
  DEACTIVATED
}

enum VerificationStatus {
  UNVERIFIED
  PHONE_VERIFIED
  IDENTITY_VERIFIED
  BUSINESS_VERIFIED
  YARTONG_VERIFIED
}

enum AuthProviderType {
  OAUTH
  EMAIL
  PHONE
  CREDENTIALS
}

model User {
  id                 String             @id @default(cuid())
  name               String?
  displayName        String
  email              String?            @unique
  emailVerified      DateTime?
  phoneNumber        String?            @unique
  image              String?
  profileImageUrl    String?
  primaryRole        UserRole
  accountStatus      AccountStatus      @default(PENDING)
  verificationStatus VerificationStatus @default(UNVERIFIED)
  locationId         String?
  location           Location?          @relation(fields: [locationId], references: [id], onDelete: SetNull)
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
  lastActiveAt       DateTime?
  isDemo             Boolean            @default(false)

  accounts                Account[]
  sessions                Session[]
  customerProfile         CustomerProfile?
  skilledProviderProfile  SkilledProviderProfile?
  labourerProfile         LabourerProfile?
  contractorProfile       ContractorProfile?
  materialSupplierProfile MaterialSupplierProfile?

  @@index([primaryRole, accountStatus])
  @@index([locationId])
}

model Account {
  id                String           @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  providerType      AuthProviderType @default(OAUTH)
  refresh_token     String?          @db.Text
  access_token      String?          @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?          @db.Text
  session_state     String?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Location {
  id        String   @id @default(cuid())
  slug      String   @unique
  name      String
  district  String
  state     String
  country   String
  pincode   String?
  latitude  Decimal? @db.Decimal(9, 6)
  longitude Decimal? @db.Decimal(9, 6)
  isActive  Boolean  @default(true)
  isPrimary Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users User[]

  @@index([district, state, country])
}

model CustomerProfile {
  id                 String   @id @default(cuid())
  userId             String   @unique
  isVerifiedBuyer    Boolean  @default(false)
  membershipPlanId   String?
  savedProviderIds   String[] @default([])
  savedSupplierIds   String[] @default([])
  savedMaterialIds   String[] @default([])
  jobsPosted         Int      @default(0)
  completedJobs      Int      @default(0)
  reviewsGiven       Int      @default(0)
  onboardingComplete Boolean  @default(false)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model SkilledProviderProfile {
  id                 String   @id @default(cuid())
  userId             String   @unique
  businessName       String?
  primaryTrade       String?
  serviceCategoryIds String[] @default([])
  yearsExperience    Int?
  bio                String?
  onboardingComplete Boolean  @default(false)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model LabourerProfile {
  id                 String   @id @default(cuid())
  userId             String   @unique
  skills             String[] @default([])
  dailyWageMin       Int?
  dailyWageMax       Int?
  bio                String?
  onboardingComplete Boolean  @default(false)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ContractorProfile {
  id                 String   @id @default(cuid())
  userId             String   @unique
  businessName       String?
  licenseNumber      String?
  teamSize           Int?
  projectTypes       String[] @default([])
  bio                String?
  onboardingComplete Boolean  @default(false)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model MaterialSupplierProfile {
  id                 String   @id @default(cuid())
  userId             String   @unique
  businessName       String?
  gstNumber          String?
  materialCategories String[] @default([])
  deliveryAvailable  Boolean  @default(false)
  bio                String?
  onboardingComplete Boolean  @default(false)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}
